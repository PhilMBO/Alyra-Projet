# ============================================
# Verivo Blockchain — Variables d'environnement
# ============================================
# Copier ce fichier en `.env` puis remplir les valeurs reelles.
# Le fichier .env est gitignore, les secrets ne seront pas commit.

# URL RPC Sepolia depuis Alchemy
# Dashboard Alchemy → ton app → API Key → HTTPS
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TA_CLE_ALCHEMY_ICI

# Cle privee du wallet deployeur (MetaMask → compte dedie → Export private key)
# ATTENTION : prefixe "0x", 64 caracteres hex apres
# Ce wallet doit contenir du SepoliaETH (~0.5 ETH suffit largement)
DEPLOYER_PRIVATE_KEY=0xTA_CLE_PRIVEE_SEPOLIA_ICI

# Cle API Etherscan pour la verification du code source
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=TA_CLE_ETHERSCAN_ICI
